###############################################################################
# SKULD Deploy Target Configuration
#
# This file controls WHICH server the GitHub Actions workflows deploy to.
# Change DEPLOY_TARGET to switch between servers — that's it.
#
# Available targets:
#   skuld-1  → Hetzner CX23, Falkenstein  (91.98.156.116)
#   skuld-2  → Hetzner CX33, Helsinki     (204.168.128.55)
#
# How it works:
#   1. Workflows read this file to determine the target server
#   2. Each target maps to a GitHub Environment with server-specific secrets
#   3. The environment provides: DEPLOY_HOST, DEPLOY_USER, DEPLOY_SSH_KEY, DEPLOY_PASSWORD
#
# To switch servers:
#   1. Change DEPLOY_TARGET below
#   2. Commit & push → next deploy goes to the new server
#   3. To rollback: change back and push again
#
# Required GitHub Environments (Settings → Environments):
#   - "skuld-1" with secrets: DEPLOY_HOST, DEPLOY_USER, DEPLOY_SSH_KEY, DEPLOY_PASSWORD
#   - "skuld-2" with secrets: DEPLOY_HOST, DEPLOY_USER, DEPLOY_SSH_KEY, DEPLOY_PASSWORD
#
###############################################################################

DEPLOY_TARGET=skuld-2

# ─── Server Registry (used by local scripts) ───────────────────────────────
# These are NOT secrets — just the IPs for local tooling (manage_local_db etc.)
SKULD1_HOST=91.98.156.116
SKULD1_NAME="Skuld (CX23, Falkenstein)"

SKULD2_HOST=204.168.128.55
SKULD2_NAME="SKULD-2 (CX33, Helsinki)"
